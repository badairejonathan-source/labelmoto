
/**
 * Moto Trust Firestore Security Rules
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------
    // Helper Functions
    // ----------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Pour le prototype, nous considérons tout utilisateur connecté comme ayant 
      // des droits d'administration sur les outils de maintenance.
      return isSignedIn() || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isCreatingOwnDoc(userId) {
      return request.resource.data.id == userId;
    }

    function idIsImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    function isCreatingOwnSubmission(professionalId) {
      return request.resource.data.professionalId == professionalId;
    }

    function submissionOwnerIsImmutable() {
      return request.resource.data.professionalId == resource.data.professionalId;
    }

    match /professionalProfiles/{professionalId} {
      allow get: if isOwner(professionalId) || isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isOwner(professionalId) && isCreatingOwnDoc(professionalId);
      allow update: if isExistingOwner(professionalId) && idIsImmutable();
      allow delete: if isExistingOwner(professionalId) || isAdmin();
    }
    
    match /standardProfiles/{userId} {
      allow get: if isOwner(userId) || isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && isCreatingOwnDoc(userId);
      allow update: if isExistingOwner(userId) && idIsImmutable();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /professionalProfiles/{professionalId}/dealershipSubmissions/{submissionId} {
      allow get: if isOwner(professionalId) || isAdmin();
      allow list: if isOwner(professionalId) || isAdmin();
      allow create: if isOwner(professionalId) && isCreatingOwnSubmission(professionalId);
      allow update: if (isExistingOwner(professionalId) && submissionOwnerIsImmutable()) || isAdmin();
      allow delete: if isExistingOwner(professionalId) || isAdmin();
    }

    match /concessions/{dealershipId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }
    
    match /pending_concessions/{submissionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /a_verifier/{submissionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /advicePosts/{advicePostId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }
  }
}
