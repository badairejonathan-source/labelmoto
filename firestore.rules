/**
 * Moto Trust Firestore Security Rules
 * Configuration sécurisée : Lecture publique pour le contenu, Modifications réservées à l'Admin.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == "A36FqeWBHjQBLKQMaMSiFVBzGV22";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /concessions/{dealershipId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /motorcycle_sheets/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /standardProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /professionalProfiles/{professionalId} {
      allow get: if isOwner(professionalId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(professionalId);
      allow update: if isOwner(professionalId);
      allow delete: if isAdmin();
    }

    match /pending_concessions/{submissionId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /pending_comments/{commentId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /a_verifier/{submissionId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read, write: if isAdmin();
    }
  }
}