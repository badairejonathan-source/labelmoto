
/**
 * Moto Trust Firestore Security Rules
 * Configuration sécurisée : Lecture publique pour le contenu, Modifications réservées à l'Admin.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------
    // Helper Functions
    // ----------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Ton UID Admin unique
      return isSignedIn() && request.auth.uid == "A36FqeWBHjQBLKQMaMSiFVBzGV22";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ----------------------------------------
    // Collections Publiques (Contenu du site)
    // ----------------------------------------

    // Concessions et Ateliers
    match /concessions/{dealershipId} {
      allow read: if true; // Tout le monde peut voir les pros
      allow write: if isAdmin(); // Seul toi peux ajouter/modifier/supprimer
      
      // Commentaires approuvés sous chaque concession
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Fiches techniques
    match /motorcycle_sheets/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Articles et Guides
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Posts de conseils
    match /advicePosts/{advicePostId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ----------------------------------------
    // Collections Privées et Modération
    // ----------------------------------------

    // Profils utilisateurs (Seul le proprio ou l'admin peut voir)
    match /standardProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /professionalProfiles/{professionalId} {
      allow get: if isOwner(professionalId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(professionalId);
      allow update: if isOwner(professionalId);
      allow delete: if isAdmin();
    }

    // Soumissions de nouveaux établissements (Public peut créer, Admin peut tout faire)
    match /pending_concessions/{submissionId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // Quarantaine automatique
    match /a_verifier/{submissionId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // Commentaires en attente de modération
    match /pending_comments/{commentId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // Rôles Admin (Stricte confidentialité)
    match /roles_admin/{uid} {
      allow read, write: if isAdmin();
    }
  }
}
