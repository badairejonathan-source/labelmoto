
{
  "entities": {
    "Dealership": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Dealership",
      "type": "object",
      "description": "Represents an approved and active motorcycle dealership listed in the Moto Trust application.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "rating": { "type": "number" },
        "category": { "type": "string" },
        "appSection": { "type": "string", "enum": ["shopping", "service", "both"] },
        "brands": { "type": "array", "items": { "type": "string" } }
      }
    },
    "TechnicalSheet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TechnicalSheet",
      "type": "object",
      "description": "Données techniques et guide d'entretien complet pour un modèle de moto.",
      "properties": {
        "id": { "type": "string" },
        "display_title": { "type": "string" },
        "brand": { "type": "string" },
        "year_range": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "technical_sheet": {
          "type": "object",
          "properties": {
            "engine_type": { "type": "string" },
            "power": { "type": "string" },
            "torque": { "type": "string" },
            "license_bridging": { "type": "string" },
            "displacement_cc": { "type": "number" },
            "fuel_system": { "type": "string" },
            "seat_height_mm": { "type": "number" },
            "weight_tpf_kg": { "type": "number" },
            "tank_l": { "type": "number" },
            "wheelbase_mm": { "type": "number" },
            "variants": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "power": { "type": "string" },
                  "torque": { "type": "string" },
                  "license_bridging": { "type": "string" }
                }
              }
            },
            "cycle_parts": {
              "type": "object",
              "properties": {
                "frame": { "type": "string" },
                "front_brake": { "type": "string" },
                "front_suspension": { "type": "string" },
                "front_tire": { "type": "string" },
                "rear_brake": { "type": "string" },
                "rear_suspension": { "type": "string" },
                "rear_tire": { "type": "string" }
              }
            }
          }
        },
        "service_guide": {
          "type": "object",
          "properties": {
            "intro": { "type": "string" },
            "conclusion": { "type": "string" },
            "service_schedule": { "type": "array", "items": { "type": "object" } },
            "consumables": { "type": "array", "items": { "type": "object" } },
            "faq": { "type": "array", "items": { "type": "object" } },
            "known_issues": { "type": "array", "items": { "type": "string" } },
            "longevity_tips": { "type": "array", "items": { "type": "string" } }
          }
        },
        "seo": { "type": "object" },
        "relations": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/concessions/{dealershipId}": {
      "schema": { "$ref": "#/backend/entities/Dealership" },
      "description": "Liste des concessions et ateliers moto."
    },
    "/motorcycle_sheets/{modelId}": {
      "schema": { "$ref": "#/backend/entities/TechnicalSheet" },
      "description": "Fiches techniques et guides d'entretien."
    }
  }
}
