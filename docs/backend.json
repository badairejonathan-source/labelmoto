
{
  "entities": {
    "Dealership": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Dealership",
      "type": "object",
      "description": "Represents an approved and active motorcycle dealership listed in the Moto Trust application.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "rating": { "type": "number" },
        "category": { "type": "string" },
        "appSection": { "type": "string", "enum": ["shopping", "service", "both"] },
        "brands": { "type": "array", "items": { "type": "string" } }
      }
    },
    "TechnicalSheet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TechnicalSheet",
      "type": "object",
      "description": "Données techniques et guide d'entretien complet pour un modèle de moto.",
      "properties": {
        "modelId": { "type": "string" },
        "modelName": { "type": "string" },
        "brand": { "type": "string" },
        "year": { "type": "string" },
        "imageUrl": { "type": "string" },
        "introduction": { "type": "string" },
        "power": { "type": "string" },
        "torque": { "type": "string" },
        "seat_height_mm": { "type": "number" },
        "tank_l": { "type": "number" },
        "weight_tpf_kg": { "type": "number" },
        "wheelbase_mm": { "type": "number" },
        "engine": { "type": "object" },
        "dimensions": { "type": "object" },
        "chassis": { "type": "object" },
        "content": { "type": "array" },
        "type": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/concessions/{dealershipId}": {
      "schema": { "$ref": "#/backend/entities/Dealership" },
      "description": "Liste des concessions et ateliers moto."
    },
    "/motorcycle_sheets/{modelId}": {
      "schema": { "$ref": "#/backend/entities/TechnicalSheet" },
      "description": "Fiches techniques et guides d'entretien."
    }
  }
}
